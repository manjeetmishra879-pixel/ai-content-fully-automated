# Application Settings
APP_NAME=AI Content Automation Platform
DEBUG=False
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_db
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRY=3600

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET=content-assets

# Vector Database
VECTOR_DB_TYPE=chroma  # 'chroma' or 'qdrant'
CHROMA_HOST=localhost
CHROMA_PORT=8000
QDRANT_URL=http://localhost:6333

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=mistral  # or llama

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT / Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys (Social Media)
GOOGLE_TRENDS_ENABLED=True
YOUTUBE_API_KEY=your-youtube-api-key
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_BEARER_TOKEN=your-x-bearer-token
INSTAGRAM_API_KEY=your-instagram-api-key
FACEBOOK_API_KEY=your-facebook-api-key
LINKEDIN_API_KEY=your-linkedin-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# External Services
GOOGLE_TRANSLATE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,mov,avi,mkv

# Performance
WORKERS_COUNT=4
TASK_MAX_RETRIES=3
TASK_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
PROMETHEUS_ENABLED=True
GRAFANA_URL=http://localhost:3000
